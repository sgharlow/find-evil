# find-evil — Environment Variables
# Copy to `.env` for local development. Do NOT commit `.env`.

# --- Evidence auto-seal -----------------------------------------------------
# If set, the MCP server auto-seals this directory at startup.
# Leave blank to require an explicit `session_init` call.
EVIDENCE_DIR=

# --- Integrity monitoring ---------------------------------------------------
# Seconds between periodic hash verification sweeps. Default: 30.
# Lower values catch tampering faster but cost more CPU.
HASH_CHECK_INTERVAL=30
