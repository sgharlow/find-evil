# Evidence Integrity Enforcer — SIFT Live Mode
#
# This Dockerfile installs all SIFT forensic tool dependencies so the
# MCP server operates in LIVE mode (real parsing) instead of simulated.
#
# Build:   docker build -f Dockerfile.sift -t find-evil-sift .
# Run:     docker run -it -v ./evidence:/evidence:ro -v ./output:/output find-evil-sift
# Tests:   docker run --rm find-evil-sift pytest tests/ -v --tb=short

FROM python:3.12-slim

LABEL maintainer="Steve Harlow <sgharlow@gmail.com>"
LABEL description="Evidence Integrity Enforcer — SIFT Live Mode with all forensic tools"

WORKDIR /app

# System dependencies for SIFT tools:
#   gcc, python3-dev   — needed to compile yara-python and python-evtx
#   libffi-dev         — needed by volatility3
#   yara               — YARA CLI (yara-python links against libyara)
#   libyara-dev        — YARA development headers for python binding
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    libffi-dev \
    yara \
    libyara-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml .
COPY src/ src/
COPY tests/ tests/
COPY demo/ demo/
COPY CLAUDE.md .
COPY README.md .
COPY LICENSE .

# Install the package WITH sift dependencies + dev dependencies
# This installs: volatility3, python-evtx, yara-python, python-registry, regipy
RUN pip install --no-cache-dir -e ".[sift,dev]"

# Create evidence mount point and output directory
RUN mkdir -p /evidence /output

# Environment defaults
ENV EVIDENCE_DIR=/evidence
ENV AUDIT_LOG_PATH=/output/audit_trail.jsonl
ENV HASH_CHECK_INTERVAL=30

# Verify SIFT tools installed correctly
RUN python -c "import Evtx; print('python-evtx OK')" && \
    python -c "import yara; print('yara-python OK')" && \
    python -c "import Registry; print('python-registry OK')" && \
    python -c "import volatility3; print('volatility3 OK')" && \
    echo "All SIFT tools verified"

# MCP server uses stdio transport
ENTRYPOINT ["python", "-m", "find_evil"]
